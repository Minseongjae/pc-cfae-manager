{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],
  "functions": {
    "api/data.ts": {
      "maxDuration": 60,
      "includeFiles": "server/**"
    },
    "api/health.ts": {
      "includeFiles": "server/**"
    }
  }
}
