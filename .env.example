# =============================================================================
# 1% PC&CAFE Manager — Google Sheets (Vercel)
# =============================================================================
# Local development: copy to `.env` and fill in values.
#   copy .env.example .env
#
# Production: set these in Vercel → Project → Settings → Environment Variables
# (server-side only — no VITE_ prefix needed for Sheets credentials)
# =============================================================================

GOOGLE_SHEETS_ID=your-google-sheet-id
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Optional — local Express API port when running `npm run dev`
PORT=3001

# Optional — only if API is on a different origin (leave empty on Vercel)
# VITE_API_URL=
