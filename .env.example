# =============================================================================
# 1% PC&CAFE Manager — Google Sheets configuration
# =============================================================================
# Copy this file to `.env` in the project root, then fill in the values below.
#
#   copy .env.example .env
#
# Spreadsheet (already created):
# https://docs.google.com/spreadsheets/d/1sWB-yFHwaL3NF5Ury00zTqtJdBxRNGGfNLczbtcQRkA/edit
# =============================================================================

# REQUIRED — your Google Sheet ID
GOOGLE_SHEETS_ID=1sWB-yFHwaL3NF5Ury00zTqtJdBxRNGGfNLczbtcQRkA

# REQUIRED — choose ONE credential method:

# Option A (recommended): path to the service account JSON key file
# Download from Google Cloud Console → IAM → Service Accounts → Keys → Add key → JSON
# Share the spreadsheet with the `client_email` from that JSON file as Editor.
GOOGLE_APPLICATION_CREDENTIALS=./credentials/google-service-account.json

# Option B: paste credentials directly (use if you cannot store a JSON file)
# GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nPASTE_KEY_HERE\n-----END PRIVATE KEY-----\n"

# API server (local development)
PORT=3001

# Optional API key — if set, the frontend must send the same value in x-api-key header
API_KEY=
VITE_API_KEY=

# Frontend API URL
# Leave empty in development — Vite proxies /api to http://localhost:3001
VITE_API_URL=
