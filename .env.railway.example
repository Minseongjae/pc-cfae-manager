# Railway production variables (API service)
#
# Create each variable manually in Railway → Service → Variables → + New Variable
# Do NOT use GOOGLE_APPLICATION_CREDENTIALS on Railway (local file paths do not exist).
#
# Required:
#   GOOGLE_SHEETS_ID=1sWB-yFHwaL3NF5Ury00zTqtJdBxRNGGfNLczbtcQRkA
#   GOOGLE_SERVICE_ACCOUNT_JSON=<paste minified JSON from prepare-railway-env.ts>
#   API_KEY=<random secret>
#
# Generate JSON value locally:
#   npx tsx scripts/prepare-railway-env.ts C:/path/to/service-account.json
#
# Optional on Railway:
#   PORT (injected automatically by Railway)

GOOGLE_SHEETS_ID=
GOOGLE_SERVICE_ACCOUNT_JSON=
API_KEY=
